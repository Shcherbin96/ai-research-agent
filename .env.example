ANTHROPIC_API_KEY=sk-ant-...

# Optional. If absent, GitHub adapter uses unauthenticated requests
# (rate limit: 10 req/min). With a token: 30 req/min.
GITHUB_TOKEN=

# Optional. If both keys are present, every node and LLM call is traced
# to Langfuse. Sign up free at https://cloud.langfuse.com.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# US region: https://us.cloud.langfuse.com — EU region: https://cloud.langfuse.com
LANGFUSE_HOST=https://cloud.langfuse.com

# Optional. If set, completed briefs are stored in Mem0 long-term memory and
# semantically-similar past briefs are recalled to seed the planner. Sign up at
# https://app.mem0.ai/dashboard. Free tier covers individual portfolio use.
MEM0_API_KEY=
# Optional namespace for memories. Default: "research-agent".
MEM0_USER_ID=
