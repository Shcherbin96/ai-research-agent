ANTHROPIC_API_KEY=sk-ant-...

# Optional. If absent, GitHub adapter uses unauthenticated requests
# (rate limit: 10 req/min). With a token: 30 req/min.
GITHUB_TOKEN=

# Optional. If both keys are present, every node and LLM call is traced
# to Langfuse. Sign up free at https://cloud.langfuse.com.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# US region: https://us.cloud.langfuse.com — EU region: https://cloud.langfuse.com
LANGFUSE_HOST=https://cloud.langfuse.com
